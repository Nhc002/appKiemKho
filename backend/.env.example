# ==========================================
# CẤU HÌNH BACKEND - Fabi Inventory System
# ==========================================

# Cổng server (Render sẽ tự gán, dev dùng 5000)
PORT=5000

# ==========================================
# SUPABASE (BẮT BUỘC cho đồng bộ cloud)
# ==========================================
# Lấy từ: https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ==========================================
# FRONTEND URL (Cho CORS - chỉ cần khi deploy)
# ==========================================
FRONTEND_URL=https://your-frontend.vercel.app

# ==========================================
# FABI iPOS API (Đồng bộ doanh số tự động)
# ==========================================
FABI_BASE_URL=https://posapi.ipos.vn
FABI_TOKEN=your-fabi-api-token
FABI_COMPANY_UID=your-company-uid
FABI_BRAND_UID=your-brand-uid
FABI_STORE_UID=your-store-uid
